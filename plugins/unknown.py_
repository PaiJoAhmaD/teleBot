from telegram import Update
from telegram.ext import MessageHandler, filters, ContextTypes

async def unknown(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Maaf, saya belum mengerti. Ketik 'bantuan' untuk melihat fitur.")

def register(app):
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, unknown), group=1)